NEXT_PUBLIC_SUPABASE_URL=https://ocosfpngrcmsolsygqxe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public site URL used for share links and callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meeting links still read this variable today.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=gmail.com
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_FROM=

# Required for TaskAI voice workspace / RTC session.
RTC_APP_ID=your_volc_rtc_app_id
RTC_APP_KEY=your_volc_rtc_app_key
VOLC_ACCESS_KEY_ID=your_volc_access_key_id
VOLC_SECRET_ACCESS_KEY=your_volc_secret_access_key
VOLC_S2S_APP_ID=your_volc_s2s_app_id
VOLC_S2S_ACCESS_TOKEN=your_volc_s2s_access_token
VOLC_S2S_MODEL=1.2.1.0

# Required for TaskAI LLM summaries.
ARK_API_KEY=your_ark_api_key
ARK_MODEL_ID=your_ark_model_id
# Optional override:
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Optional storage override.
# SUPABASE_STORAGE_AUDIO_BUCKET=conversation-audio

# Required for local WhatsApp bridge polling.
# TASKAI_BASE_URL=http://localhost:3000
# TASKAI_INTERNAL_BRIDGE_TOKEN=replace_with_a_long_random_secret
# OPENCLAW_WHATSAPP_ADDR=http://127.0.0.1:8555

# Optional front-end toggles / legacy meeting features.
# NEXT_PUBLIC_LLM_PROVIDER=respond_stream
# LLM_FALLBACK_PROVIDER=respond_stream
# NEXT_PUBLIC_ASR_MODE=dify
# NEXT_PUBLIC_DIFY_SERVER=https://your-dify-server.com/v1
# NEXT_PUBLIC_DIFY_API_KEY=your-dify-api-key
# ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
# ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# ALIYUN_ASR_APP_KEY=your-aliyun-asr-app-key
# ALIYUN_TTS_APP_KEY=your-aliyun-tts-app-key
# ALIYUN_REGION=cn-shanghai
# NEXT_PUBLIC_TTS_PROVIDER=byteplus
# BYTEPLUS_TTS_APP_ID=your-byteplus-tts-app-id
# BYTEPLUS_ACCESS_TOKEN=your-byteplus-access-token
# BYTEPLUS_TTS_TOKEN=your-byteplus-tts-token
# BYTEPLUS_TTS_VOICE_TYPE=your-byteplus-voice-type
